{
  "include": ["src/**/*.ts"],
  "exclude": ["src/**/*.test.ts","src/**/*.vscode-test.ts"],
  "compilerOptions": {
    "declaration": true,
    "emitDeclarationOnly": false,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "skipLibCheck": true,
    "strict": true,
    "target": "ESNext",
    "rootDir": "src",
    "outDir": "dist"
  }
}
